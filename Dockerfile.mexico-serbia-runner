# Worker: espera kickoff y simula México vs Serbia vía webhook.
FROM node:22-alpine
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm install --omit=dev
COPY scripts/load-env-local.mjs scripts/load-env-local.mjs
COPY scripts/cargar-pilot-mexico-serbia.mjs scripts/cargar-pilot-mexico-serbia.mjs
COPY scripts/replay-mexico-serbia-live.mjs scripts/replay-mexico-serbia-live.mjs
COPY scripts/run-mexico-serbia-live-runner.mjs scripts/run-mexico-serbia-live-runner.mjs
CMD ["node", "scripts/run-mexico-serbia-live-runner.mjs"]
